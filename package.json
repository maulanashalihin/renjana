{
  "name": "renjana",
  "version": "0.0.1",
  "description": "Laju Go - High-performance SaaS boilerplate built with Go Fiber, Svelte 5, and Inertia.js",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:go": "air",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:go\"",
    "build": "vite build",
    "build:all": "vite build && go build -o laju-go ./cmd/laju-go",
    "build:go": "go build -o laju-go ./cmd/laju-go",
    "build:linux": "cross-env GOOS=linux GOARCH=amd64 go build -o laju-go ./cmd/laju-go",
    "deploy": "./scripts/deploy.sh",
    "serve": "go run ./cmd/laju-go",
    "db:refresh": "rimraf ./data/app.db ./data/app.db-shm ./data/app.db-wal",
    "db:migrate": "goose -dir migrations sqlite ./data/app.db up",
    "db:migrate:status": "goose -dir migrations sqlite ./data/app.db status",
    "db:migrate:down": "goose -dir migrations sqlite ./data/app.db down",
    "db:migrate:create": "goose -dir migrations create",
    "db:generate": "sqlc generate",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "author": "Maulana Shalihin",
  "license": "MIT",
  "dependencies": {
    "@inertiajs/svelte": "^3.0.0",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "leaflet": "^1.9.4",
    "lucide-svelte": "^1.0.1"
  },
  "devDependencies": {
    "@inertiajs/vite": "^3.0.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/svelte": "^5.3.1",
    "@tsconfig/svelte": "^5.0.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "happy-dom": "^20.8.9",
    "postcss": "^8.5.8",
    "rimraf": "^6.1.3",
    "svelte": "^5.55.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
