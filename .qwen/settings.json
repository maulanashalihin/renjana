{
  "permissions": {
    "allow": [
      "Bash(go *)",
      "Bash(sqlc *)",
      "Bash(rm *)",
      "Bash(git rm *)",
      "Bash(git pull *)",
      "Bash(git stash)"
    ]
  },
  "mcpServers": {
    "gortex": {
      "command": "gortex",
      "args": ["mcp", "--index", ".", "--watch"],
      "trust": true
    }
  },
  "$version": 3
}