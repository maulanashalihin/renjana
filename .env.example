# Server Configuration
APP_PORT=8080
APP_ENV=development

# Database Configuration
DB_PATH=./data/app.db

# Session Configuration
SESSION_SECRET=your-secret-key-change-this-in-production

# Cache Configuration
# Session cache TTL (default: 5m). In-memory cache avoids DB lookup on every request.
SESSION_CACHE_TTL=5m
# User profile cache TTL (default: 15m). Set to 0 to disable.
USER_CACHE_TTL=15m

# Argon2id Configuration
# Memory cost in KiB. Default: 65536 (64MB). Min: 1024, Max: 1048576.
# Time cost (iterations). Default: 3. Parallelism (threads). Default: 4.
ARGON2_MEMORY=65536
ARGON2_TIME=3
ARGON2_THREADS=4

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@example.com
FROM_NAME=Laju Go

# Application URL (for password reset links)
APP_URL=http://localhost:8080
